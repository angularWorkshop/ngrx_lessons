{
  "name": "@angular-workshop/ngrx-lessons",
  "version": "0.1.0",
  "private": true,
  "description": "EduTec NgRx course practice exercises",
  "stackblitz": {
    "startCommand": "npm run start:dev"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test",
    "start:dev": "node scripts/stackblitz-status.mjs",
    "pack:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
